RewriteEngine On

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.monvesto\.de$ [NC]
RewriteRule ^(.*)$ https://www.monvesto.de/$1 [R=301,L]

# Affiliate-Weiterleitungen
RewriteRule ^go/([a-z0-9-]+)/?$ /go/index.php?partner=$1 [L,QSA]

# Alte Seiten endgültig entfernen
RewriteRule ^contact(/.*)?$ - [G,L]
RewriteRule ^service(/.*)?$ - [G,L]
RewriteRule ^copytrading(/.*)?$ - [G,L]
RewriteRule ^tools-partner(/.*)?$ - [G,L]
RewriteRule ^link-hub(/.*)?$ - [G,L]
RewriteRule ^uncategorized(/.*)?$ - [G,L]
RewriteRule ^imprint(/.*)?$ - [G,L]


# Duplicates entfernen, solange es keine echten Seiten sind
RewriteRule ^module(/.*)?$ - [G,L]
RewriteRule ^transaktionen(/.*)?$ - [G,L]

# Monvesto .htaccess

# MIME Types
AddType text/css .css
AddType application/javascript .js

# PHP als Standard
DirectoryIndex index.php index.html

# Fehlerseite
ErrorDocument 404 /404.php

# Kein Verzeichnis-Listing
Options -Indexes